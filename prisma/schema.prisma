generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
  master_admin
  monitor
  dispatcher

  @@map("user_role")
}

model User {
  id           Int       @id @default(autoincrement())
  openId       String    @unique @db.VarChar(64)
  name         String?
  lastName     String?
  email        String?   @db.VarChar(320)
  phone        String?   @db.VarChar(20)
  loginMethod  String?   @db.VarChar(64)
  password     String?   @db.VarChar(255)
  role         UserRole  @default(user)
  status       String    @default("pending") @db.VarChar(20)
  empresaId    Int?
  avatarUrl    String?
  bio          String?
  cargo        String?
  departamento String?
  idioma       String?
  tema         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSignedIn DateTime  @default(now())
  deletedAt    DateTime?
  deletedBy    Int?
  deleteReason String?

  empresaPrincipal Empresa?             @relation("UserEmpresaPrincipal", fields: [empresaId], references: [id])
  companyAccess    UserCompanyAccess[]
  userPermissoes   UserPermissao[]
  auditLogs        AuditLog[]
  auditoriaDetalhe AuditoriaDetalhada[]
  masterClients    MasterClient[]                @relation("MasterClientsOwner")
  masterTasks      MasterTask[]                  @relation("MasterTasksOwner")
  masterFinancial  MasterFinancialTransaction[]  @relation("MasterFinancialOwner")
  masterEvents     MasterCalendarEvent[]         @relation("MasterCalendarOwner")
  masterReminders  MasterReminder[]              @relation("MasterRemindersOwner")

  @@map("users")
}

model Empresa {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(255)
  cnpj          String?  @db.VarChar(18)
  telefone      String?  @db.VarChar(20)
  email         String?  @db.VarChar(320)
  endereco      String?
  cidade        String?  @db.VarChar(100)
  estado        String?  @db.VarChar(2)
  ativo         Boolean  @default(true)
  agentToken    String?
  codigoConvite String?  @unique @db.VarChar(50)
  tipoEmpresa   String   @default("independente") @db.VarChar(20)
  matrizId      Int?
  parentId      Int?     @map("parent_id")
  grupoId       Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  deletedBy     Int?
  deleteReason  String?

  usuariosPrincipais User[]              @relation("UserEmpresaPrincipal")
  companyAccess      UserCompanyAccess[]
  rolePermissoes     ModuloPermissao[]
  userPermissoes     UserPermissao[]
  grupoVinculos      GrupoEmpresa[]
  grupo              GrupoEmpresarial?   @relation(fields: [grupoId], references: [id])
  auditLogs          AuditLog[]
  auditoriaDetalhe   AuditoriaDetalhada[]
  notifications      Notification[]
  veiculos           Veiculo[]
  funcionarios       Funcionario[]
  contasPagar        ContaPagar[]
  contasReceber      ContaReceber[]
  viagens            Viagem[]
  ticketsTi          TicketTi[]

  @@map("empresas")
}

model GrupoEmpresarial {
  id           Int       @id @default(autoincrement())
  nome         String    @db.VarChar(255)
  cnpj         String?   @db.VarChar(18)
  descricao    String?
  adminUserId  Int?
  ativo        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedBy    Int?
  deleteReason String?

  empresas Empresa[]
  vinculos GrupoEmpresa[]

  @@map("grupos_empresariais")
}

model GrupoEmpresa {
  id        Int      @id @default(autoincrement())
  grupoId   Int
  empresaId Int
  papel     String   @default("filial") @db.VarChar(20)
  createdAt DateTime @default(now())

  grupo   GrupoEmpresarial @relation(fields: [grupoId], references: [id])
  empresa Empresa          @relation(fields: [empresaId], references: [id])

  @@map("grupo_empresas")
}

model UserCompanyAccess {
  id           Int      @id @default(autoincrement())
  userId       Int
  empresaId    Int
  roleCode     String   @db.VarChar(50)
  canViewGroup Boolean  @default(false)
  isDefault    Boolean  @default(false)
  ativo        Boolean  @default(true)
  createdBy    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  deletedBy    Int?
  deleteReason String?

  user    User    @relation(fields: [userId], references: [id])
  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("user_company_access")
}

model ModuloPermissao {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  roleCode    String   @db.VarChar(50)
  modulo      String   @db.VarChar(100)
  podeVer     Boolean  @default(false)
  podeCriar   Boolean  @default(false)
  podeEditar  Boolean  @default(false)
  podeDeletar Boolean  @default(false)
  podeExportar Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, roleCode, modulo])
  @@map("modulo_permissoes")
}

model UserPermissao {
  id           Int      @id @default(autoincrement())
  userId       Int
  empresaId    Int
  modulo       String   @db.VarChar(100)
  podeVer      Boolean  @default(false)
  podeCriar    Boolean  @default(false)
  podeEditar   Boolean  @default(false)
  podeDeletar  Boolean  @default(false)
  podeExportar Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("user_permissoes")
}

model AuditLog {
  id         BigInt    @id @default(autoincrement())
  empresaId  Int?
  userId     Int
  userName   String?   @db.VarChar(255)
  acao       String    @db.VarChar(50)
  tabela     String    @db.VarChar(100)
  registroId Int
  dadosAntes String?
  dadosDepois String?
  ip         String?   @db.VarChar(45)
  userAgent  String?
  createdAt  DateTime  @default(now())

  empresa Empresa? @relation(fields: [empresaId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

model AuditoriaDetalhada {
  id          BigInt    @id @default(autoincrement())
  empresaId   Int?
  userId      Int
  userName    String?   @db.VarChar(255)
  userRole    String?   @db.VarChar(50)
  tipoEvento  String    @db.VarChar(50)
  modulo      String?   @db.VarChar(100)
  tabela      String?   @db.VarChar(100)
  registroId  Int?
  descricao   String
  dadosAntes  String?
  dadosDepois String?
  ip          String?   @db.VarChar(45)
  userAgent   String?
  sessionId   String?   @db.VarChar(100)
  risco       String?   @default("baixo") @db.VarChar(20)
  createdAt   DateTime  @default(now())

  empresa Empresa? @relation(fields: [empresaId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@map("auditoria_detalhada")
}

model Notification {
  id        BigInt    @id @default(autoincrement())
  empresaId Int?
  userId    Int?
  tipo      String    @db.VarChar(50)
  titulo    String    @db.VarChar(255)
  mensagem  String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  empresa Empresa? @relation(fields: [empresaId], references: [id])

  @@map("notifications")
}

model Veiculo {
  id               Int       @id @default(autoincrement())
  empresaId        Int
  placa            String    @db.VarChar(10)
  tipo             String    @db.VarChar(30)
  ativo            Boolean   @default(true)
  kmAtual          Int?
  vencimentoCrlv   DateTime?
  vencimentoSeguro DateTime?
  deletedAt        DateTime?
  deletedBy        Int?
  deleteReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("veiculos")
}

model Funcionario {
  id              Int       @id @default(autoincrement())
  empresaId       Int
  nome            String    @db.VarChar(255)
  funcao          String?   @db.VarChar(50)
  tipoContrato    String?   @db.VarChar(30)
  ativo           Boolean   @default(true)
  diaPagamento    Int?
  vencimentoCnh   DateTime?
  deletedAt       DateTime?
  deletedBy       Int?
  deleteReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("funcionarios")
}

model ContaPagar {
  id             Int       @id @default(autoincrement())
  empresaId      Int
  descricao      String    @db.VarChar(255)
  categoria      String    @db.VarChar(50)
  valor          Decimal   @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String    @db.VarChar(20)
  deletedAt      DateTime?
  deletedBy      Int?
  deleteReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("contas_pagar")
}

model ContaReceber {
  id              Int       @id @default(autoincrement())
  empresaId       Int
  descricao       String    @db.VarChar(255)
  categoria       String    @db.VarChar(50)
  valor           Decimal   @db.Decimal(10, 2)
  dataVencimento  DateTime
  dataRecebimento DateTime?
  status          String    @db.VarChar(20)
  deletedAt       DateTime?
  deletedBy       Int?
  deleteReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("contas_receber")
}

model Viagem {
  id            Int       @id @default(autoincrement())
  empresaId     Int
  status        String    @db.VarChar(30)
  freteTotal    Decimal?  @db.Decimal(10, 2)
  totalDespesas Decimal?  @db.Decimal(10, 2)
  saldoViagem   Decimal?  @db.Decimal(10, 2)
  dataChegada   DateTime?
  kmSaida       Int?
  kmChegada     Int?
  veiculoId     Int?
  deletedAt     DateTime?
  deletedBy     Int?
  deleteReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("viagens")
}

model TicketTi {
  id            Int       @id @default(autoincrement())
  empresaId     Int
  protocolo     String    @db.VarChar(20)
  solicitanteId Int
  titulo        String    @db.VarChar(255)
  descricao     String
  categoria     String    @db.VarChar(50)
  prioridade    String    @db.VarChar(20)
  status        String    @db.VarChar(30)
  responsavelId Int?
  resolucao     String?
  resolvidoEm   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("tickets_ti")
}

model MasterClient {
  id          Int       @id @default(autoincrement())
  ownerUserId Int
  nome        String    @db.VarChar(255)
  empresa     String?   @db.VarChar(255)
  contato     String?   @db.VarChar(255)
  whatsapp    String?   @db.VarChar(30)
  email       String?   @db.VarChar(320)
  servicos    String?
  valorMensal Decimal?  @db.Decimal(12, 2)
  status      String    @default("lead") @db.VarChar(30)
  dataInicio  DateTime? @db.Date
  proximaAcao String?
  observacoes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  owner      User                           @relation("MasterClientsOwner", fields: [ownerUserId], references: [id])
  tasks      MasterTask[]
  financeiro MasterFinancialTransaction[]
  eventos    MasterCalendarEvent[]

  @@map("master_clients")
}

model MasterTask {
  id          Int       @id @default(autoincrement())
  ownerUserId Int
  clientId    Int?
  titulo      String    @db.VarChar(255)
  descricao   String?
  area        String    @default("synapse") @db.VarChar(30)
  status      String    @default("a_fazer") @db.VarChar(30)
  prioridade  String    @default("media") @db.VarChar(20)
  periodo     String    @default("manha") @db.VarChar(20)
  dataLimite  DateTime?
  concluidaEm DateTime?
  ordem       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  owner  User         @relation("MasterTasksOwner", fields: [ownerUserId], references: [id])
  client MasterClient? @relation(fields: [clientId], references: [id])

  @@map("master_tasks")
}

model MasterFinancialTransaction {
  id             Int       @id @default(autoincrement())
  ownerUserId    Int
  clientId       Int?
  tipo           String    @db.VarChar(20)
  categoria      String?   @db.VarChar(100)
  descricao      String    @db.VarChar(255)
  valor          Decimal   @db.Decimal(12, 2)
  status         String    @default("pendente") @db.VarChar(20)
  vencimento     DateTime? @db.Date
  pagoEm         DateTime?
  formaPagamento String?   @map("formaPagamento") @db.VarChar(50)
  observacoes    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  owner  User         @relation("MasterFinancialOwner", fields: [ownerUserId], references: [id])
  client MasterClient? @relation(fields: [clientId], references: [id])

  @@map("master_financial_transactions")
}

model MasterCalendarEvent {
  id               Int       @id @default(autoincrement())
  ownerUserId      Int
  clientId         Int?
  titulo           String    @db.VarChar(255)
  descricao        String?
  area             String    @default("vida") @db.VarChar(30)
  tipo             String    @default("compromisso") @db.VarChar(50)
  inicio           DateTime
  fim              DateTime?
  local            String?   @db.VarChar(255)
  lembreteMinutos  Int?      @default(30)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  owner  User         @relation("MasterCalendarOwner", fields: [ownerUserId], references: [id])
  client MasterClient? @relation(fields: [clientId], references: [id])

  @@map("master_calendar_events")
}

model MasterReminder {
  id          Int       @id @default(autoincrement())
  ownerUserId Int
  titulo      String    @db.VarChar(255)
  descricao   String?
  status      String    @default("pendente") @db.VarChar(20)
  lembrarEm   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  owner User @relation("MasterRemindersOwner", fields: [ownerUserId], references: [id])

  @@map("master_reminders")
}
