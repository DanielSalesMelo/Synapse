{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synapse Agent",
  "version": "0.1.0",
  "identifier": "com.synapse.agent",
  "build": {
    "beforeDevCommand": "pnpm --filter ui dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter ui build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Suporte Synapse",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
