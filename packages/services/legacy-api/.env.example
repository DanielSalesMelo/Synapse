# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:SENHA@crossover.proxy.rlwy.net:40549/railway

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres

# ─── Configurações do App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CORS / Frontend ──────────────────────────────────────────────────────────
FRONTEND_URL=https://synapse-seven-nu.vercel.app

# ─── Owner (Master Admin) ─────────────────────────────────────────────────────
# OpenID do usuário que será automaticamente promovido a master_admin
OWNER_OPEN_ID=seu_open_id_aqui

# ─── OAuth (opcional) ─────────────────────────────────────────────────────────
OAUTH_SERVER_URL=
VITE_APP_ID=synapse

# ─── OpenAI (módulo de IA) ────────────────────────────────────────────────────
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
