# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:SENHA@crossover.proxy.rlwy.net:40549/railway

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres

# ─── Configurações do App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CORS / Frontend ──────────────────────────────────────────────────────────
FRONTEND_URL=https://synapse-seven-nu.vercel.app

# ─── Owner (Master Admin) ─────────────────────────────────────────────────────
# OpenID do usuário que será automaticamente promovido a master_admin
OWNER_OPEN_ID=seu_open_id_aqui

# ─── OAuth (opcional) ─────────────────────────────────────────────────────────
OAUTH_SERVER_URL=
VITE_APP_ID=synapse

# ─── Auth0 + Google Login (opcional, recomendado) ────────────────────────────
# No Auth0, habilite a conexão Google e configure callback:
# https://SEU_BACKEND.azurewebsites.net/api/auth/auth0/callback
AUTH0_DOMAIN=seu-tenant.us.auth0.com
AUTH0_CLIENT_ID=seu_client_id
AUTH0_CLIENT_SECRET=seu_client_secret
AUTH0_CONNECTION_GOOGLE=google-oauth2
AUTH0_CONNECTION_MICROSOFT=windowslive
AUTH0_CONNECTION_APPLE=apple
# Em produção, deixe false para não aceitar qualquer origem vercel.app
ALLOW_ANY_VERCEL_ORIGIN=false

# ─── OpenAI (módulo de IA) ────────────────────────────────────────────────────
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
