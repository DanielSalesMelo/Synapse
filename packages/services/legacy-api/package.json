    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
